{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Pratapan",
  "version": "0.1.0",
  "identifier": "com.pratapan.app",
  "build": {
    "frontendDist": "..",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": {
      "script": "pnpm exec vite",
      "wait": false
    },
    "beforeBuildCommand": "pnpm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Pratapan",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/pratapan-sidecar"
    ]
  }
}
