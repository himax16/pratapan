{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-execute",
    "shell:allow-kill",
    {
      "identifier": "shell:allow-spawn",
      "allow": [{ "name": "pratapan-sidecar", "sidecar": true }]
    }
  ]
}
